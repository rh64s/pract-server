{
    "name": "rh64s/pract-server",
    "description": "practic for server part",
    "type": "project",
    "license": "MIT",
    "config": {
        "platform": {
            "php": "8.2"
        }
    },
    "authors": [
        {
            "name": "rh64s",
            "email": "cchelovekov64@gmail.com"
        }
    ],
    "minimum-stability": "dev",
    "require": {
        "php": "^8.1",
        "illuminate/database": "12.x-dev",
        "illuminate/events": "12.x-dev",
        "nikic/fast-route": "^2.0@dev",
        "twbs/bootstrap": "5.0.2"
    },
    "autoload": {
        "psr-4": {
            "Src\\": "core/Src/",
            "Debug\\": "core/Debug/",
            "": "app/"
        }
    },
    "scripts": {
        "post-update-cmd": [
            "rm -rf public/bootstrap",
            "cp -R vendor/twbs/bootstrap/dist public/bootstrap"
        ]
    }
}
